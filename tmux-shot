#!/usr/bin/env python3
"""tmux-shot: 将终端文本渲染为 PNG 截图，忠实还原 Ghostty + One Half Dark 的显示效果。

用法:
  pbpaste | tmux-shot              # 管道输入，生成截图
  tmux-shot                        # 自动读系统剪贴板
  tmux-shot --open                 # 生成后打开预览
  tmux-shot --light                # 亮色主题
  tmux-shot --clipboard            # 同时复制图片到系统剪贴板
"""

import sys
import argparse
import subprocess
import unicodedata
from pathlib import Path
from datetime import datetime
from PIL import Image, ImageDraw, ImageFont

# ── 字体 ─────────────────────────────────────────────────
FONT_PATH = str(Path.home() / "Library/Fonts/DejaVuSansMNerdFontMono-Regular.ttf")
CJK_FONT_CANDIDATES = [
    "/System/Library/Fonts/Hiragino Sans GB.ttc",
    "/System/Library/Fonts/STHeiti Medium.ttc",
    "/System/Library/Fonts/Supplemental/Songti.ttc",
]

# ── One Half Dark / Light 配色 ───────────────────────────
BG_DARK  = (40, 44, 52)       # #282c34
FG_DARK  = (220, 223, 228)    # #dcdfe4
BG_LIGHT = (250, 250, 250)    # #fafafa
FG_LIGHT = (56, 58, 66)       # #383a42

# ── 渲染参数 ─────────────────────────────────────────────
FONT_SIZE   = 16    # 逻辑像素
PADDING     = 20    # 逻辑像素
LINE_HEIGHT = 1.35  # 行高倍数
SCALE       = 2     # Retina 2x
TAB_WIDTH   = 8


def load_cjk_font(size: int) -> ImageFont.FreeTypeFont | None:
    for path in CJK_FONT_CANDIDATES:
        try:
            return ImageFont.truetype(path, size, index=0)
        except Exception:
            continue
    return None


def char_display_width(c: str) -> int:
    """终端显示宽度：全角/宽字符返回 2，其余返回 1。"""
    return 2 if unicodedata.east_asian_width(c) in ("F", "W") else 1


def render(text: str, args) -> Image.Image:
    scale = args.scale
    font_size = args.font_size * scale
    padding = args.padding * scale

    primary = ImageFont.truetype(args.font, font_size)
    cjk = load_cjk_font(font_size)

    # 等宽格子宽度（单个 ASCII 字符宽度）
    cell_w = primary.getlength("M")

    # 行高
    ascent, descent = primary.getmetrics()
    line_step = int((ascent + descent) * args.line_height)

    # 预处理文本
    text = text.expandtabs(TAB_WIDTH)
    lines = text.split("\n")
    while lines and lines[-1] == "":
        lines.pop()
    if not lines:
        lines = [""]

    # 计算画布尺寸（按终端格子数）
    max_cells = 0
    for line in lines:
        cells = sum(char_display_width(c) for c in line)
        max_cells = max(max_cells, cells)

    img_w = int(cell_w * max_cells) + padding * 2
    img_h = line_step * len(lines) + padding * 2

    img = Image.new("RGB", (img_w, img_h), args.bg)
    draw = ImageDraw.Draw(img)

    y = padding
    for line in lines:
        if not line:
            y += line_step
            continue

        # 快速判断：纯 ASCII 行可以整行渲染
        has_wide = any(char_display_width(c) == 2 for c in line)

        if not has_wide:
            draw.text((padding, y), line, font=primary, fill=args.fg)
        else:
            # 逐字符渲染，按终端格子对齐
            x = float(padding)
            for char in line:
                w = char_display_width(char)
                if w == 2 and cjk is not None:
                    # CJK 字符：用 CJK 字体，居中在双格子内
                    cjk_w = cjk.getlength(char)
                    offset = (cell_w * 2 - cjk_w) / 2
                    draw.text((x + offset, y), char, font=cjk, fill=args.fg)
                else:
                    draw.text((x, y), char, font=primary, fill=args.fg)
                x += cell_w * w
        y += line_step

    return img


def parse_color(value):
    """接受 tuple 或 '#rrggbb' 字符串，返回 (r, g, b) tuple。"""
    if isinstance(value, tuple):
        return value
    h = value.lstrip("#")
    return (int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16))


def main():
    p = argparse.ArgumentParser(description="将终端文本渲染为 PNG 截图")
    p.add_argument("-o", "--output", help="输出路径（默认 /tmp/tmux-shot-<时间戳>.png）")
    p.add_argument("--font", default=FONT_PATH, help="字体文件路径")
    p.add_argument("--font-size", type=int, default=FONT_SIZE)
    p.add_argument("--padding", type=int, default=PADDING)
    p.add_argument("--line-height", type=float, default=LINE_HEIGHT)
    p.add_argument("--scale", type=int, default=SCALE)
    p.add_argument("--bg", default=None, help="背景色 hex")
    p.add_argument("--fg", default=None, help="前景色 hex")
    p.add_argument("--light", action="store_true", help="亮色主题")
    p.add_argument("--open", action="store_true", help="生成后用预览打开")
    p.add_argument("--clipboard", action="store_true", help="同时复制图片到系统剪贴板")

    args = p.parse_args()

    # 主题
    if args.light:
        args.bg = args.bg or BG_LIGHT
        args.fg = args.fg or FG_LIGHT
    else:
        args.bg = args.bg or BG_DARK
        args.fg = args.fg or FG_DARK
    args.bg = parse_color(args.bg)
    args.fg = parse_color(args.fg)

    # 读取文本
    if sys.stdin.isatty():
        text = subprocess.check_output(["pbpaste"], text=True)
    else:
        text = sys.stdin.read()

    if not text.strip():
        print("tmux-shot: 没有内容可渲染", file=sys.stderr)
        sys.exit(1)

    # 输出路径
    if not args.output:
        ts = datetime.now().strftime("%Y%m%d-%H%M%S")
        args.output = f"/tmp/tmux-shot-{ts}.png"

    img = render(text, args)

    dpi = 72 * args.scale
    img.save(args.output, "PNG", dpi=(dpi, dpi))
    print(args.output)

    if args.clipboard:
        subprocess.run([
            "osascript", "-e",
            f'set the clipboard to (read (POSIX file "{args.output}") as «class PNGf»)',
        ])

    if args.open:
        subprocess.run(["open", args.output])


if __name__ == "__main__":
    main()
